#!/usr/bin/env python3
"""claude-resume — Resume any Claude Code conversation.

A more powerful alternative to the built-in /resume. Shows ALL conversations
(including background jobs and orphaned sessions), restores the original working
directory, and displays rich metadata.

Usage:
  claude-resume                    # current project, all conversations
  claude-resume -A                 # pick from ALL projects first, then conversation
  claude-resume -b                 # bg/orphan only (exclude interactive)
  claude-resume -p /path/to/proj   # specific project
  claude-resume --no-cd            # don't auto-chdir to original CWD before resume
  claude-resume --help
"""

import argparse
import json
import os
import shutil
import sys
from datetime import datetime, timezone, timedelta

# ── Terminal styling ──────────────────────────────────────────────────────────

BOLD = "\033[1m"
CYAN = "\033[1;36m"
YELLOW = "\033[1;33m"
GRAY = "\033[90m"
GREEN = "\033[32m"
MAGENTA = "\033[35m"
RED = "\033[31m"
DIM = "\033[2m"
RESET = "\033[0m"


# ── Helpers ───────────────────────────────────────────────────────────────────

def normalize_path(path: str) -> str:
    p = os.path.realpath(path)
    return "-" + p.lstrip("/").replace("/", "-")


def format_size(size_bytes: int) -> str:
    if size_bytes >= 1_048_576:
        return f"{size_bytes / 1_048_576:.1f}MB"
    if size_bytes >= 1024:
        return f"{size_bytes // 1024}KB"
    return f"{size_bytes}B"


def format_time(ts: str) -> str:
    if not ts or ts == "unknown":
        return "????-??-?? ??:??"
    try:
        return ts[:19].replace("T", " ")
    except Exception:
        return "unknown"


def time_ago(ts: str) -> str:
    if not ts or ts == "unknown":
        return ""
    try:
        dt = datetime.fromisoformat(ts[:19].replace("Z", "+00:00"))
        diff = datetime.now(timezone.utc) - dt
        s = diff.total_seconds()
        if s < 60:
            return "just now"
        if s < 3600:
            return f"{int(s // 60)}m ago"
        if s < 86400:
            return f"{int(s // 3600)}h ago"
        if s < 604800:
            return f"{int(s // 86400)}d ago"
        return f"{int(s // 604800)}w ago"
    except Exception:
        return ""


def build_time_filter(args) -> tuple[datetime | None, datetime | None]:
    """Return (since, until) from CLI flags. Both are timezone-aware UTC.
    Time macros set defaults; explicit --since/--until override the corresponding bound."""
    now = datetime.now(timezone.utc)
    since: datetime | None = None
    until: datetime | None = None

    if args.today:
        since = now.replace(hour=0, minute=0, second=0, microsecond=0)
    elif args.yesterday:
        yesterday = now - timedelta(days=1)
        since = yesterday.replace(hour=0, minute=0, second=0, microsecond=0)
        until = yesterday.replace(hour=23, minute=59, second=59, microsecond=999999)
    elif args.this_week:
        monday = now - timedelta(days=now.weekday())
        since = monday.replace(hour=0, minute=0, second=0, microsecond=0)

    if args.since:
        since = datetime.strptime(args.since, "%Y-%m-%d").replace(tzinfo=timezone.utc)
    if args.until:
        until = datetime.strptime(args.until, "%Y-%m-%d").replace(hour=23, minute=59, second=59, microsecond=999999, tzinfo=timezone.utc)

    return since, until


def apply_time_filter(conversations: list, since, until) -> list:
    """Filter conversations by time range. `last_active_raw` is ISO timestamp string."""
    result = []
    for c in conversations:
        ts = c.get("last_active_raw", "")
        if not ts:
            continue
        try:
            dt = datetime.fromisoformat(ts[:19].replace("Z", "+00:00"))
        except (ValueError, TypeError):
            continue
        if since and dt < since:
            continue
        if until and dt > until:
            continue
        result.append(c)
    return result


def search_preview(conversations: list, keyword: str) -> list:
    """Case-insensitive keyword match against preview text."""
    kw = keyword.lower()
    return [c for c in conversations if kw in c.get("preview", "").lower()]


def search_full(store: str, conversations: list, keyword: str, max_results: int) -> list:
    """Case-insensitive keyword match scanning entire JSONL files. Only scans
    up to max_results files, in the order they appear in `conversations`."""
    kw = keyword.lower()
    matched_ids = set()
    for c in conversations[:max_results]:
        path = os.path.join(store, c["session_id"] + ".jsonl")
        try:
            with open(path) as fh:
                if kw in fh.read().lower():
                    matched_ids.add(c["session_id"])
        except Exception:
            continue
    return [c for c in conversations if c["session_id"] in matched_ids]


def apply_search_filter(store: str, conversations: list, args) -> list:
    """Apply keyword search; dispatch to preview or full-text mode."""
    if not args.search:
        return conversations
    if args.search_full:
        return search_full(store, conversations, args.search, args.max_results)
    return search_preview(conversations, args.search)


def output_json(conversations: list):
    """Print conversations as JSON to stdout."""
    out = []
    for c in conversations:
        out.append({
            "session_id": c["session_id"],
            "short_id": c["short_id"],
            "size_kb": c.get("size_kb", 0),
            "msg_count": c["msg_count"],
            "last_active": c["last_active"],
            "preview": c["preview"],
            "kind": c["kind"],
            "status": c.get("status", ""),
            "name": c.get("name", ""),
            "cwd": c.get("cwd", ""),
        })
    json.dump(out, sys.stdout, indent=2)
    sys.stdout.write("\n")


def output_oneline(conversations: list):
    """Print conversations as compact single-line entries."""
    for c in conversations:
        line = (
            f"{c['short_id']}  {c['last_active']}  {c['kind']}  "
            f"{c.get('status', '')}  {c['size_str']}  {c['msg_count']}msgs  "
            f"{c['preview']}"
        )
        print(line)


def show_info(conversation: dict):
    """Print detailed session info."""
    print(f"Session:  {conversation['session_id']}")
    print(f"Kind:     {conversation['kind']}")
    print(f"Status:   {conversation.get('status', 'unknown')}")
    print(f"Name:     {conversation.get('name', '') or '(none)'}")
    print(f"CWD:      {conversation.get('cwd', '') or '(unknown)'}")
    print(f"Size:     {conversation['size_str']}")
    print(f"Messages: {conversation['msg_count']}")
    print(f"Last:     {conversation['last_active']}")
    print(f"Preview:  {conversation['preview']}")


def delete_session(conversation: dict, store: str, sessions_dir: str, force: bool):
    """Delete .jsonl and session .json files. Prompts for confirmation in TTY."""
    sid = conversation["session_id"]

    if not force:
        if os.isatty(sys.stdin.fileno()):
            try:
                ans = input(f"Delete session {sid[:8]}? [y/N]: ").strip().lower()
            except (EOFError, KeyboardInterrupt):
                print("Cancelled.")
                sys.exit(0)
            if ans != "y":
                print("Cancelled.")
                sys.exit(0)
        else:
            print("Non-TTY: use --force to delete without confirmation.", file=sys.stderr)
            sys.exit(1)

    jsonl_path = os.path.join(store, sid + ".jsonl")
    try:
        os.remove(jsonl_path)
        print(f"Deleted: {jsonl_path}")
    except OSError as e:
        print(f"Warning: could not delete {jsonl_path}: {e}", file=sys.stderr)

    sess_path = os.path.join(sessions_dir, sid + ".json")
    if os.path.isfile(sess_path):
        try:
            os.remove(sess_path)
            print(f"Deleted: {sess_path}")
        except OSError as e:
            print(f"Warning: could not delete {sess_path}: {e}", file=sys.stderr)


def resolve_selection(conversations: list, args) -> dict | None:
    """Return a single conversation dict if non-interactive selection succeeds,
    or None if interactive TUI is needed."""
    if args.last:
        return conversations[0] if conversations else None
    if args.index is not None:
        idx = args.index - 1  # 1-indexed -> 0-indexed
        if 0 <= idx < len(conversations):
            return conversations[idx]
        print(f"Invalid index: {args.index} (max {len(conversations)})", file=sys.stderr)
        sys.exit(1)
    if len(conversations) == 1:
        return conversations[0]
    return None


def term_width() -> int:
    try:
        return os.get_terminal_size().columns
    except OSError:
        return 120


# ── Session registry ──────────────────────────────────────────────────────────

def load_session_registry(sessions_dir: str) -> dict:
    """Return {session_id: {kind, status, name, cwd, pid}} from session files.
    Later entries override earlier ones; 'busy' status takes priority."""
    registry = {}
    if not os.path.isdir(sessions_dir):
        return registry
    for fname in os.listdir(sessions_dir):
        if not fname.endswith(".json"):
            continue
        try:
            with open(os.path.join(sessions_dir, fname)) as f:
                d = json.load(f)
        except Exception:
            continue
        sid = d.get("sessionId", "")
        if not sid:
            continue
        existing = registry.get(sid)
        # Prefer entries with status, and don't downgrade busy -> idle
        if existing and existing.get("status") == "busy":
            continue
        if existing and not d.get("status") and existing.get("status"):
            continue
        registry[sid] = {
            "kind": d.get("kind", ""),
            "status": d.get("status", ""),
            "name": d.get("name", ""),
            "cwd": d.get("cwd", ""),
            "pid": d.get("pid", 0),
        }
    return registry


# ── Conversation scanning ─────────────────────────────────────────────────────

def extract_metadata(path: str) -> dict:
    """Extract metadata from a conversation JSONL file in one pass."""
    info = {"lines": 0, "first_user_msg": "", "last_ts": "", "cwd": ""}
    try:
        with open(path) as fh:
            for line in fh:
                info["lines"] += 1
                try:
                    d = json.loads(line)
                except json.JSONDecodeError:
                    continue

                ts = d.get("timestamp", "")
                if ts:
                    info["last_ts"] = ts

                cwd = d.get("cwd", "")
                if cwd and not info["cwd"]:
                    info["cwd"] = cwd

                if info["first_user_msg"]:
                    continue

                msg = d.get("message", {})
                if not isinstance(msg, dict) or msg.get("role") != "user":
                    continue

                content = msg.get("content", "")
                texts = []
                if isinstance(content, list):
                    for c in content:
                        if c.get("type") == "text":
                            texts.append(c.get("text", ""))
                elif isinstance(content, str):
                    texts.append(content)

                for txt in texts:
                    txt = txt.strip()
                    if not txt:
                        continue
                    if txt.startswith("<command") or txt.startswith("<local-command"):
                        continue
                    info["first_user_msg"] = txt
                    break
                if not info["first_user_msg"]:
                    for txt in texts:
                        txt = txt.strip()
                        if txt and not txt.startswith("<command") and not txt.startswith("<local-command"):
                            info["first_user_msg"] = txt
                            break
    except Exception:
        pass
    return info


def scan_conversations(store: str, sessions_dir: str, bg_only: bool) -> list:
    """Scan project store; return list of conversation dicts (newest first)."""
    registry = load_session_registry(sessions_dir)
    results = []

    if not os.path.isdir(store):
        return results

    for fname in sorted(os.listdir(store), reverse=True):
        if not fname.endswith(".jsonl"):
            continue
        path = os.path.join(store, fname)
        session_id = fname.replace(".jsonl", "")

        reg = registry.get(session_id, {})
        kind = reg.get("kind", "")
        status = reg.get("status", "")
        session_name = reg.get("name", "")
        session_cwd = reg.get("cwd", "")

        # In bg_only mode, skip interactive sessions that /resume handles
        if bg_only and kind == "interactive":
            continue

        try:
            fsize = os.path.getsize(path)
        except OSError:
            continue

        meta = extract_metadata(path)

        preview = meta["first_user_msg"].replace("\n", " ").replace("\r", " ")
        if len(preview) > 120:
            preview = preview[:117] + "..."
        if not preview:
            preview = "(empty)"

        # CWD: prefer session-file cwd, fall back to JSONL cwd
        cwd = session_cwd or meta["cwd"] or ""

        # Kind label for display: fallback for orphaned conversations
        display_kind = kind or "orphan"

        results.append({
            "session_id": session_id,
            "short_id": session_id[:8],
            "size_str": format_size(fsize),
            "size_kb": fsize // 1024,
            "msg_count": meta["lines"],
            "last_active": format_time(meta["last_ts"]),
            "last_active_raw": meta["last_ts"],
            "preview": preview,
            "kind": display_kind,
            "status": status,
            "name": session_name,
            "cwd": cwd,
        })

    return results


# ── Display ───────────────────────────────────────────────────────────────────

def kind_badge(kind: str, status: str) -> str:
    if status == "busy":
        return f"{RED}active{RESET}"
    if kind == "interactive":
        if status == "idle":
            return f"{GREEN}idle{RESET}"
        return f"{GREEN}interactive{RESET}"
    if kind == "bg":
        return f"{YELLOW}bg{RESET}"
    return f"{MAGENTA}orphan{RESET}"


def display_list(conversations: list, project_name: str, bg_only: bool):
    header = "Background conversations" if bg_only else "All conversations"
    tw = term_width()
    preview_w = max(25, tw - 65)

    print()
    bar = "─" * (min(tw, 100) - 4)
    print(f"  {DIM}╭─{bar}╮{RESET}")
    print(f"  {DIM}│{RESET}  {BOLD}{header}{RESET} in {CYAN}{project_name}{RESET}")
    if not bg_only:
        print(f"  {DIM}│{RESET}  {GRAY}claude-resume -b   # bg/orphan only     claude-resume -A   # all projects{RESET}")
    print(f"  {DIM}╰─{bar}╯{RESET}")
    print()

    for i, c in enumerate(conversations, 1):
        idx = f"[{i}]"
        sid = c["short_id"]
        size = c["size_str"]
        msgs = f"{c['msg_count']} msgs"
        date = c["last_active"]
        kb = kind_badge(c["kind"], c["status"])
        preview = c["preview"]
        ago = time_ago(c["last_active_raw"])
        name = c["name"]

        p = preview
        if len(p) > preview_w:
            p = p[: preview_w - 3] + "..."

        line1 = (
            f"  {YELLOW}{idx:>4}{RESET}  {BOLD}{sid}{RESET}  {kb}  "
            f"{GRAY}{date:>16}{RESET}  {size:>6}  {msgs:>6}"
        )
        if ago:
            line1 += f"  {DIM}({ago}){RESET}"

        print(line1)
        print(f"       {GRAY}{p}{RESET}")

        # Extra line: name and cwd
        extras = []
        if name:
            extras.append(f"name: {name}")
        cwd = c.get("cwd", "")
        if cwd:
            cwd_short = cwd.replace(os.path.expanduser("~"), "~")
            extras.append(f"cwd: {cwd_short}")
        if extras:
            print(f"       {DIM}{'  |  '.join(extras)}{RESET}")

        print()

    print(f"  {DIM}[q]  quit{RESET}")


# ── Selection ─────────────────────────────────────────────────────────────────

def select_interactive(conversations: list) -> str | None:
    n = len(conversations)
    try:
        choice = input(f"\n  Select [1-{n}] or q: ").strip()
    except (EOFError, KeyboardInterrupt):
        print()
        return None

    if choice.lower() == "q" or not choice:
        return None

    if not choice.isdigit() or not (1 <= int(choice) <= n):
        print(f"  {RED}Invalid selection: {choice}{RESET}")
        sys.exit(1)

    return conversations[int(choice) - 1]["session_id"]


# ── Main ──────────────────────────────────────────────────────────────────────

def build_parser() -> argparse.ArgumentParser:
    p = argparse.ArgumentParser(
        prog="claude-resume",
        description="Resume Claude Code conversations — interactive TUI or non-interactive.",
    )

    # Selection
    sel = p.add_argument_group("selection")
    sel.add_argument("-l", "--last", action="store_true", help="Most recent session")
    sel.add_argument("-i", "--index", type=int, metavar="N", help="Nth session (1-indexed)")
    sel.add_argument("-s", "--search", metavar="KW", help="Keyword search (single match = immediate)")
    sel.add_argument("--search-full", action="store_true", help="Search full JSONL, not just preview")
    sel.add_argument("--max-results", type=int, default=50, metavar="N", help="Max files for --search-full (default 50)")

    # Filtering
    filt = p.add_argument_group("filtering")
    filt.add_argument("-b", "--bg", action="store_true", help="Background/orphan sessions only")
    filt.add_argument("-t", "--today", action="store_true", help="Today only")
    filt.add_argument("-y", "--yesterday", action="store_true", help="Yesterday only")
    filt.add_argument("-w", "--this-week", action="store_true", help="This week only")
    filt.add_argument("--since", metavar="DATE", help="Start date (YYYY-MM-DD)")
    filt.add_argument("--until", metavar="DATE", help="End date (YYYY-MM-DD)")
    filt.add_argument("-A", "--all-projects", action="store_true", help="Pick from all projects first")
    filt.add_argument("-p", "--project", metavar="PATH", help="Target a specific project")
    filt.add_argument("-n", "--limit", type=int, metavar="N", help="Max entries in TUI")

    # Output
    out = p.add_argument_group("output (non-interactive)")
    out.add_argument("-j", "--json", action="store_true", help="JSON to stdout")
    out.add_argument("--oneline", action="store_true", help="Compact single-line per session")
    out.add_argument("--no-color", action="store_true", help="Strip ANSI codes")

    # Terminal
    term = p.add_argument_group("terminal multiplexer")
    term.add_argument("--zellij", nargs="?", const="tab", choices=["tab", "pane", "float"],
                      help="Open in Zellij (default: tab)")
    term.add_argument("--tmux", nargs="?", const="window", choices=["window", "pane"],
                      help="Open in tmux (default: window)")
    term.add_argument("--terminal-cmd", metavar="TMPL", help="Custom terminal cmd with {cwd} and {cmd}")

    # Claude args
    cl = p.add_argument_group("claude arguments")
    cl.add_argument("-B", "--background", action="store_true", help="Launch Claude with --bg")
    cl.add_argument("-C", "--claude-args", default="", metavar="ARGS", help="Extra args passed to claude")

    # Management
    mgmt = p.add_argument_group("session management")
    mgmt.add_argument("--info", action="store_true", help="Show session details, no resume")
    mgmt.add_argument("--rm", action="store_true", help="Delete session")
    mgmt.add_argument("-f", "--force", action="store_true", help="Skip --rm confirmation")
    mgmt.add_argument("-c", "--count", action="store_true", help="Print count only")
    mgmt.add_argument("--dry-run", action="store_true", help="List but don't resume")

    # Other
    other = p.add_argument_group("other")
    other.add_argument("--no-cd", action="store_true", help="Don't chdir before resume")

    return p


# ── All-projects mode ─────────────────────────────────────────────────────────

def decode_project_name(norm: str) -> str:
    """Decode a normalized path back to something readable.
    '-home-matrix-project-foo' -> '~/project/foo'"""
    if norm.startswith("-"):
        path = "/" + norm[1:].replace("-", "/")
        home = os.path.expanduser("~")
        if path.startswith(home):
            return "~" + path[len(home):]
        return path
    return norm


def scan_all_projects(projects_base: str, sessions_dir: str, bg_only: bool) -> list:
    """Return list of {name, path, norm, conv_count, last_active} for all projects."""
    result = []
    if not os.path.isdir(projects_base):
        return result

    registry = load_session_registry(sessions_dir)

    for norm in sorted(os.listdir(projects_base)):
        store = os.path.join(projects_base, norm)
        if not os.path.isdir(store):
            continue

        # Count conversations and find latest activity
        conv_count = 0
        latest_ts = ""
        for fname in os.listdir(store):
            if not fname.endswith(".jsonl"):
                continue
            sid = fname.replace(".jsonl", "")
            reg = registry.get(sid, {})
            if bg_only and reg.get("kind") == "interactive":
                continue
            conv_count += 1
            # Quick timestamp check
            path = os.path.join(store, fname)
            try:
                with open(path) as fh:
                    for line in fh:
                        try:
                            d = json.loads(line)
                            ts = d.get("timestamp", "")
                            if ts and ts > latest_ts:
                                latest_ts = ts
                        except json.JSONDecodeError:
                            continue
            except Exception:
                pass

        if conv_count == 0:
            continue

        name = decode_project_name(norm)
        result.append({
            "name": name,
            "norm": norm,
            "store": store,
            "conv_count": conv_count,
            "last_active": format_time(latest_ts),
            "last_active_raw": latest_ts,
        })

    # Sort by last active, newest first
    result.sort(key=lambda x: x["last_active_raw"] or "", reverse=True)
    return result


def select_project(projects: list) -> str | None:
    """Display project list and let user pick one. Returns the store path."""
    tw = term_width()
    print()
    bar = "─" * (min(tw, 100) - 4)
    print(f"  {DIM}╭─{bar}╮{RESET}")
    print(f"  {DIM}│{RESET}  {BOLD}All projects{RESET}")
    print(f"  {DIM}╰─{bar}╯{RESET}")
    print()

    for i, p in enumerate(projects, 1):
        idx = f"[{i}]"
        name = p["name"]
        count = f"{p['conv_count']} sessions"
        date = p["last_active"]
        ago = time_ago(p["last_active_raw"])

        line = (
            f"  {YELLOW}{idx:>4}{RESET}  {BOLD}{name}{RESET}  "
            f"{GRAY}{count:>12}{RESET}  {DIM}last: {date}{RESET}"
        )
        if ago:
            line += f"  {DIM}({ago}){RESET}"
        print(line)

    print()

    n = len(projects)
    try:
        choice = input(f"  Select project [1-{n}] or q: ").strip()
    except (EOFError, KeyboardInterrupt):
        print()
        return None

    if choice.lower() == "q" or not choice:
        return None

    if not choice.isdigit() or not (1 <= int(choice) <= n):
        print(f"  {RED}Invalid selection: {choice}{RESET}")
        sys.exit(1)

    return projects[int(choice) - 1]["store"]


def init_colors_off():
    """Disable all ANSI color codes for --no-color mode."""
    global BOLD, CYAN, YELLOW, GRAY, GREEN, MAGENTA, RED, DIM, RESET
    BOLD = CYAN = YELLOW = GRAY = GREEN = MAGENTA = RED = DIM = RESET = ""


def detect_multiplexers() -> dict:
    """Return available terminal multiplexers with their modes.
    Format: {"zellij": [("mode_key", "label"), ...], "tmux": [...]}"""
    available = {}
    if os.environ.get("ZELLIJ") and shutil.which("zellij"):
        available["zellij"] = [
            ("tab", "New Zellij tab"),
            ("pane-right", "New Zellij pane (split right)"),
            ("pane-down", "New Zellij pane (split down)"),
            ("float", "New Zellij floating pane"),
        ]
    if os.environ.get("TMUX") and shutil.which("tmux"):
        available["tmux"] = [
            ("window", "New tmux window"),
            ("pane-right", "New tmux pane (split right)"),
            ("pane-down", "New tmux pane (split down)"),
        ]
    return available


def build_multiplexer_cmd(mux: str, mode: str, cwd: str, cmd: str) -> list[str]:
    """Build the multiplexer command that wraps the claude invocation."""
    if mux == "zellij":
        if mode == "tab":
            return ["zellij", "action", "new-tab", "--cwd", cwd, "--", *cmd.split()]
        elif mode == "pane-right":
            return ["zellij", "action", "new-pane", "-d", "right", "--cwd", cwd, "--", *cmd.split()]
        elif mode == "pane-down":
            return ["zellij", "action", "new-pane", "-d", "down", "--cwd", cwd, "--", *cmd.split()]
        elif mode == "float":
            return ["zellij", "action", "new-pane", "--floating", "--cwd", cwd, "--", *cmd.split()]
    elif mux == "tmux":
        if mode == "window":
            return ["tmux", "new-window", "-c", cwd, cmd]
        elif mode == "pane-right":
            return ["tmux", "split-window", "-h", "-c", cwd, cmd]
        elif mode == "pane-down":
            return ["tmux", "split-window", "-v", "-c", cwd, cmd]
    return cmd.split()


def expand_terminal_cmd(template: str, cwd: str, cmd: str) -> list[str]:
    """Expand {cwd} and {cmd} in custom terminal command template."""
    expanded = template.replace("{cwd}", cwd).replace("{cmd}", cmd)
    return expanded.split()


def prompt_terminal(mux_available: dict, args) -> tuple[str | None, str | None]:
    """Interactive prompt for terminal choice. Returns (multiplexer, mode) or (None, None)
    for current terminal. Respects --zellij/--tmux as pre-selected defaults."""
    default_mux = None
    default_mode = None
    if args.zellij:
        default_mux = "zellij"
        default_mode = args.zellij
    elif args.tmux:
        default_mux = "tmux"
        default_mode = args.tmux

    if not mux_available:
        return None, None

    # Validate default: only apply if that multiplexer is actually available
    if default_mux and default_mux not in mux_available:
        default_mux = None
        default_mode = None

    options = [("current", "Current terminal")]
    default_idx = None
    for mux_name, modes in mux_available.items():
        for mode_key, mode_label in modes:
            options.append((f"{mux_name}:{mode_key}", mode_label))
            if mux_name == default_mux and mode_key == default_mode:
                default_idx = len(options) - 1

    print()
    print(f"  Open in:")
    for i, (key, label) in enumerate(options):
        marker = " (default)" if i == default_idx else ""
        print(f"  [{i+1}] {label}{marker}")
    default_hint = f" or Enter for [{default_idx + 1}]" if default_idx is not None else ""
    print(f"  Select [1-{len(options)}]{default_hint}: ", end="")

    try:
        choice = input().strip()
    except (EOFError, KeyboardInterrupt):
        print()
        return None, None

    if not choice:
        if default_idx is not None:
            key = options[default_idx][0]
            if key == "current":
                return None, None
            mux, mode = key.split(":", 1)
            return mux, mode
        return None, None

    try:
        idx = int(choice) - 1
        if 0 <= idx < len(options):
            key = options[idx][0]
            if key == "current":
                return None, None
            mux, mode = key.split(":", 1)
            return mux, mode
    except (ValueError, IndexError):
        pass

    return None, None


def main():
    parser = build_parser()
    args = parser.parse_args()

    if args.no_color:
        init_colors_off()

    sessions_dir = os.path.join(os.path.expanduser("~"), ".claude", "sessions")
    projects_base = os.path.join(os.path.expanduser("~"), ".claude", "projects")

    # ── All-projects mode: pick project first ─────────────────────────────
    if args.all_projects:
        if not os.isatty(sys.stdin.fileno()):
            print("--all-projects requires an interactive terminal.", file=sys.stderr)
            sys.exit(1)

        projects = scan_all_projects(projects_base, sessions_dir, args.bg)
        if not projects:
            print("No projects with conversations found.")
            sys.exit(0)

        store = select_project(projects)
        if store is None:
            sys.exit(0)

        # Decode project name for display
        project_name = os.path.basename(store)  # normalized name, overridden below
        # Find project entry to get display name
        for p in projects:
            if p["store"] == store:
                project_name = p["name"]
                break
    else:
        project_dir = os.path.realpath(args.project or os.getcwd())
        norm = normalize_path(project_dir)
        store = os.path.join(projects_base, norm)
        project_name = os.path.basename(project_dir)

    # Fast path: --count (no need to read JSONL content)
    if args.count:
        fnames = [f for f in os.listdir(store) if f.endswith(".jsonl")] if os.path.isdir(store) else []
        if args.bg:
            registry = load_session_registry(sessions_dir)
            fnames = [f for f in fnames
                      if registry.get(f.replace(".jsonl", ""), {}).get("kind") != "interactive"]
        print(len(fnames))
        sys.exit(0)

    # ── Conversation selection ────────────────────────────────────────────
    conversations = scan_conversations(store, sessions_dir, args.bg)

    # Time filter
    try:
        since, until = build_time_filter(args)
    except ValueError as e:
        print(f"Invalid date: {e}", file=sys.stderr)
        sys.exit(2)
    if since or until:
        conversations = apply_time_filter(conversations, since, until)

    # Search filter
    conversations = apply_search_filter(store, conversations, args)

    # Non-interactive output modes
    if args.json:
        output_json(conversations)
        sys.exit(0)
    if args.oneline:
        output_oneline(conversations)
        sys.exit(0)

    # Resolve selection (non-interactive if possible)
    selected = resolve_selection(conversations, args)

    # If we got a single session, resume it directly (non-interactive path)
    if selected is not None:
        if args.info:
            show_info(selected)
            sys.exit(0)
        if args.rm:
            delete_session(selected, store, sessions_dir, args.force)
            sys.exit(0)
        if args.dry_run:
            display_list([selected], project_name, args.bg)
            sys.exit(0)
        resume_session(selected, args)
        return

    if not conversations:
        if args.bg:
            print("No background/orphaned conversations — use /resume or claude-resume (without -b).")
        else:
            print("No conversations found for this project.")
        sys.exit(0)

    display_list(conversations, project_name, args.bg)

    if not os.isatty(sys.stdin.fileno()):
        print("\n  (non-interactive — pipe in a number: echo 2 | claude-resume)")
        sys.exit(0)

    session_id = select_interactive(conversations)
    if session_id is None:
        sys.exit(0)

    selected = next((c for c in conversations if c["session_id"] == session_id), None)
    if selected:
        # Terminal multiplexer prompt (interactive only)
        mux_available = detect_multiplexers()
        mux, mode = None, None
        if mux_available:
            mux, mode = prompt_terminal(mux_available, args)

        # Interactive: prompt for extra Claude args (e.g. --bg, --fast)
        extra_args = ""
        try:
            prompt = "  Claude args (e.g. --bg, --fast) or Enter to skip: "
            extra_args = input(prompt).strip()
        except (EOFError, KeyboardInterrupt):
            pass

        resume_session(selected, args, mux=mux, mode=mode, extra_args=extra_args)
    else:
        # Fallback: should not happen
        os.execvp("claude", ["claude", "--resume", session_id])


def resume_session(conversation: dict, args, mux=None, mode=None, extra_args=""):
    """Execute the resume: chdir, build command, optionally wrap in multiplexer, exec."""
    cwd = conversation.get("cwd", "") or os.getcwd()
    if cwd and os.path.isdir(cwd) and not args.no_cd:
        os.chdir(cwd)
    elif cwd and not os.path.isdir(cwd) and not args.no_cd:
        print(f"  {YELLOW}Warning: original cwd no longer exists: {cwd}{RESET}")

    cmd_parts = ["claude", "--resume", conversation["session_id"]]
    if args.background:
        cmd_parts.append("--bg")
    if args.claude_args:
        cmd_parts.extend(args.claude_args.split())
    if extra_args:
        cmd_parts.extend(extra_args.split())

    if args.no_cd:
        print(f"\n  {GREEN}Resuming {conversation['short_id']}...{RESET}\n")
    else:
        print(f"\n  {GREEN}Resuming {conversation['short_id']}...  (cwd: {os.getcwd()}){RESET}\n")
    cmd_str = " ".join(cmd_parts)

    if args.terminal_cmd:
        exec_cmd = expand_terminal_cmd(args.terminal_cmd, cwd, cmd_str)
    elif mux and mode:
        exec_cmd = build_multiplexer_cmd(mux, mode, cwd, cmd_str)
    else:
        exec_cmd = cmd_parts

    os.execvp(exec_cmd[0], exec_cmd)


if __name__ == "__main__":
    main()
